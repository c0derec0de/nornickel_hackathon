# Скопируй в .env: cp .env.example .env

# =========================================================================
# LLM провайдер. Выбери ОДИН вариант (раскомментируй нужные строки).
# По правилам хакатона: только НЕпроприетарные модели, доступные из РФ.
# Anthropic/OpenAI — ЗАПРЕЩЕНЫ. OpenRouter — разрешён.
# =========================================================================

# --- Вариант A: Локальная модель через Ollama (по умолчанию, приватно, без лимитов) ---
# Требуется на машине: ollama + `ollama pull qwen2.5:7b-instruct`
# (для слабого железа: qwen2.5:3b-instruct ~2ГБ)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b-instruct
OLLAMA_HOST=http://host.docker.internal:11434

# --- Вариант B: OpenRouter (OpenAI-совместимый, разрешён в РФ) ---
# Раскомментируй и впиши ключ с https://openrouter.ai/keys.
# ВНИМАНИЕ: бесплатные :free-модели часто отдают 429 (rate limit).
# LLM_PROVIDER=openai
# LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...

# Мультиязычные эмбеддинги (RU/EN), опенсорс, локально (fastembed, ONNX)
EMBED_MODEL=intfloat/multilingual-e5-large

# Запрещён по правилам хакатона — не используется
ANTHROPIC_API_KEY=
