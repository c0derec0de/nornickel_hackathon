# Скопируй в .env: cp .env.example .env

# =========================================================================
# LLM провайдер. По правилам хакатона: только НЕпроприетарные модели,
# доступные из РФ. Anthropic/OpenAI — ЗАПРЕЩЕНЫ. OpenRouter — разрешён.
# =========================================================================

# --- Вариант A: Ollama как СЕРВИС в docker-compose (по умолчанию) ---
# Ничего ставить не надо: `docker compose up` сам поднимет ollama и скачает модель.
# Модель qwen2.5:14b-instruct (Q4 ≈9ГБ, нужно ~10-11ГБ RAM) — сильный RU/EN + JSON.
# Слабое железо → поставь qwen2.5:3b-instruct (~1.9ГБ) или 7b (~4.7ГБ).
# Другая квантизация → тег, напр. qwen2.5:14b-instruct-q4_0 / -q5_K_M.
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:14b-instruct
OLLAMA_HOST=http://ollama:11434

# --- Вариант A' (Mac, для скорости через Metal): host-Ollama ---
# Контейнерный Ollama на Mac идёт на CPU. Быстрее — свой ollama на хосте:
#   brew services start ollama && ollama pull qwen2.5:3b-instruct
# и переопредели хост (+ подними стек без ollama-сервиса):
#   OLLAMA_HOST=http://host.docker.internal:11434
#   docker compose up -d --scale ollama=0 --scale ollama-pull=0

# --- Вариант B: OpenRouter (OpenAI-совместимый, разрешён в РФ) ---
# ВНИМАНИЕ: бесплатные :free-модели часто отдают 429 (rate limit).
# LLM_PROVIDER=openai
# LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...

# Мультиязычные эмбеддинги (RU/EN), опенсорс, локально (fastembed, ONNX)
EMBED_MODEL=intfloat/multilingual-e5-large

# Запрещён по правилам хакатона — не используется
ANTHROPIC_API_KEY=
