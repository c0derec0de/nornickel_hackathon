# Скопируй в .env: cp .env.example .env

# =========================================================================
# LLM провайдер. По правилам хакатона: только НЕпроприетарные модели,
# доступные из РФ. Anthropic/OpenAI — ЗАПРЕЩЕНЫ. OpenRouter — разрешён.
# =========================================================================

# --- Вариант A: Ollama как СЕРВИС в docker-compose (по умолчанию) ---
# Ничего ставить не надо: `docker compose up` сам поднимет ollama и скачает модель.
# Модель qwen3:4b (Q4 ~2.5ГБ, нужно ~5-6ГБ RAM) — свежий Qwen3, сильный RU/EN + JSON.
# Больше точности / есть RAM → qwen2.5:14b-instruct (~9ГБ) или qwen3:8b (~5ГБ).
# Совсем слабое железо → qwen3:1.7b / qwen2.5:3b-instruct.
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b
OLLAMA_HOST=http://ollama:11434

# --- Вариант A' (Mac, для скорости через Metal): host-Ollama ---
# Контейнерный Ollama на Mac идёт на CPU. Быстрее — свой ollama на хосте:
#   brew services start ollama && ollama pull qwen2.5:3b-instruct
# и переопредели хост (+ подними стек без ollama-сервиса):
#   OLLAMA_HOST=http://host.docker.internal:11434
#   docker compose up -d --scale ollama=0 --scale ollama-pull=0

# --- Вариант B: LM Studio (локальный OpenAI-совместимый сервер) ---
# В LM Studio: вкладка Developer → Start Server (порт 1234), загрузи модель (напр. qwen3-4b).
# Бэкенд в Docker обращается к хосту через host.docker.internal. Ключ любой непустой.
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=http://host.docker.internal:1234/v1
# OPENAI_API_KEY=lm-studio
# LLM_MODEL=qwen3-4b          # точный id из LM Studio (GET /v1/models)
# Стек без контейнера ollama: docker compose up -d --scale ollama=0 --scale ollama-pull=0

# --- Вариант C: OpenRouter (OpenAI-совместимый, разрешён в РФ) ---
# ВНИМАНИЕ: бесплатные :free-модели часто отдают 429 (rate limit).
# LLM_PROVIDER=openai
# LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...

# Мультиязычные эмбеддинги (RU/EN), опенсорс, локально (fastembed, ONNX)
EMBED_MODEL=intfloat/multilingual-e5-large

# Запрещён по правилам хакатона — не используется
ANTHROPIC_API_KEY=
